# Copy this file to .env.production, replace every placeholder, then deploy with:
# docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

# Public web entrypoint
PROCUREX_SITE_ADDRESS=procurex.example.com
CADDY_ACME_EMAIL=admin@example.com
APP_PUBLIC_URL=https://procurex.example.com
CORS_ORIGINS=https://procurex.example.com

# Runtime
APP_ENV=production
NODE_ENV=production
PORT=4000
REQUEST_BODY_LIMIT=160mb

# Database
POSTGRES_DB=procurex
POSTGRES_USER=procurex
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
DATABASE_URL=postgresql://procurex:replace-with-a-long-random-postgres-password@postgres:5432/procurex
DIRECT_URL=postgresql://procurex:replace-with-a-long-random-postgres-password@postgres:5432/procurex

# Redis and search
REDIS_URL=redis://redis:6379
ELASTICSEARCH_URL=http://elasticsearch:9200
COMPLIANCE_SEARCH_INDEX=procurex-compliance-admin

# S3-compatible document storage through bundled MinIO
MINIO_ROOT_USER=procurex
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=procurex
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-minio-password
S3_FORCE_PATH_STYLE=true
S3_DOCUMENT_BUCKET=procurex-documents
DOCUMENT_STORAGE_DRIVER=s3
BID_DOCUMENT_STORAGE_DRIVER=s3
BID_DOCUMENT_MAX_BYTES=26214400
DOCUMENT_MAX_UPLOAD_BYTES=26214400
PROFILE_IMAGE_UPLOAD_DIR=.data/profile-images
PROFILE_IMAGE_MAX_BYTES=2097152
OFFICIAL_DOCUMENT_UPLOAD_DIR=.data/official-documents

# Browser security
TURNSTILE_SECRET_KEY=replace-with-cloudflare-turnstile-secret
VITE_TURNSTILE_SITE_KEY=replace-in-vercel-or-web-build-if-hosting-frontend-separately

# Identity notifications
IDENTITY_EMAIL_PROVIDER=resend
IDENTITY_PHONE_PROVIDER=sms
IDENTITY_SMS_PROVIDER=briq
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM=ProcureX <no-reply@example.com>
RESEND_REPLY_TO=support@example.com
BRIQ_API_KEY=replace-with-briq-api-key
BRIQ_SMS_BASE_URL=https://karibu.briq.tz
BRIQ_SMS_SENDER=BRIQ
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SMS_BASE_URL=https://apisms.beem.africa
BEEM_SMS_SENDER=ProcureX
BEEM_WHATSAPP_ENABLED=false
BEEM_WHATSAPP_FROM=
BEEM_WHATSAPP_TEMPLATE_OTP=

# Registry and email validation providers
TRA_REGISTRY_BASE_URL=https://replace-with-tra-registry-url
TRA_REGISTRY_API_KEY=replace-with-tra-api-key
BRELA_REGISTRY_BASE_URL=https://replace-with-brela-registry-url
BRELA_REGISTRY_API_KEY=replace-with-brela-api-key
MAILBOXLAYER_ACCESS_KEY=replace-with-mailboxlayer-key
MAILBOXLAYER_BASE_URL=https://apilayer.net/api/check
MAILBOXLAYER_EMAIL_VALIDATION_ENABLED=true
MAILBOXLAYER_MIN_SCORE=0.60
MAILBOXLAYER_BLOCK_DISPOSABLE=true
MAILBOXLAYER_BLOCK_ROLE_EMAILS=false
MAILBOXLAYER_REQUIRE_SMTP=false
MAILBOXLAYER_SMTP_CHECK=true

# Signing, encryption, and limits
SIGNATURE_HASH_SECRET=replace-with-long-random-signature-secret
BID_ENCRYPTION_KEY=replace-with-32-byte-bid-encryption-key
BID_DOCUMENT_ENCRYPTION_KEY_REF=production-v1
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
API_MUTATION_RATE_LIMIT_MAX=120
API_MUTATION_RATE_LIMIT_WINDOW_SECONDS=60

# Support email
SUPPORT_EMAIL_TO=support@example.com
