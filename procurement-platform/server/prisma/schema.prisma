model MarketSnapshot {
  id         String   @id @default(uuid()) @db.Uuid
  ownerOrgId String?  @map("owner_org_id") @db.Uuid
  name       String
  payload    Json     @default("{}")
  capturedAt DateTime @default(now()) @map("captured_at")

  @@index([ownerOrgId, capturedAt])
  @@map("market_snapshots")
  @@schema("intelligence")
}

model PriceBenchmark {
  id         String      @id @default(uuid()) @db.Uuid
  ownerOrgId String?     @map("owner_org_id") @db.Uuid
  tenderType TenderType? @map("tender_type")
  category   String?
  payload    Json        @default("{}")
  capturedAt DateTime    @default(now()) @map("captured_at")

  @@index([ownerOrgId])
  @@index([tenderType, category])
  @@map("price_benchmarks")
  @@schema("intelligence")
}

model SupplierMatchSignal {
  id            String   @id @default(uuid()) @db.Uuid
  tenderId      String?  @map("tender_id") @db.Uuid
  supplierOrgId String?  @map("supplier_org_id") @db.Uuid
  score         Int?
  payload       Json     @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  tender        Tender?  @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId])
  @@index([supplierOrgId])
  @@map("supplier_match_signals")
  @@schema("intelligence")
}

model ModuleRegistry {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  status    String   @default("Available")
  version   String
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("module_registry")
  @@schema("intelligence")
}

model PublicPageVersion {
  id                 String                 @id @default(uuid()) @db.Uuid
  pageKey            PublicPageKey          @map("page_key")
  version            String
  status             PublicPageStatus       @default(DRAFT)
  title              String
  summary            String?
  content            Json                   @default("{}")
  contentHash        String                 @map("content_hash")
  effectiveAt        DateTime               @map("effective_at")
  publishedAt        DateTime?              @map("published_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  termsAcceptances   UserPolicyAcceptance[] @relation("TermsPolicyAcceptances")
  privacyAcceptances UserPolicyAcceptance[] @relation("PrivacyPolicyAcceptances")

  @@unique([pageKey, version])
  @@index([pageKey, status, effectiveAt])
  @@map("public_page_versions")
  @@schema("content")
}

model DataStoreEntry {
  id              String                  @id @default(uuid()) @db.Uuid
  scope           String                  @default("GLOBAL")
  ownerUserId     String?                 @map("owner_user_id") @db.Uuid
  namespace       String
  key             String
  value           Json                    @default("{}")
  encrypted       Boolean                 @default(false)
  createdByUserId String?                 @map("created_by_user_id") @db.Uuid
  updatedByUserId String?                 @map("updated_by_user_id") @db.Uuid
  deletedByUserId String?                 @map("deleted_by_user_id") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  deletedAt       DateTime?               @map("deleted_at")
  ownerUser       User?                   @relation("DataStoreOwnerUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  createdByUser   User?                   @relation("DataStoreCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User?                   @relation("DataStoreUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  deletedByUser   User?                   @relation("DataStoreDeletedByUser", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  versions        DataStoreEntryVersion[]

  @@index([scope])
  @@index([namespace])
  @@index([key])
  @@index([ownerUserId])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("data_store_entries")
  @@schema("content")
}

model DataStoreEntryVersion {
  id            String         @id @default(uuid()) @db.Uuid
  entryId       String         @map("entry_id") @db.Uuid
  actorUserId   String?        @map("actor_user_id") @db.Uuid
  action        String
  previousValue Json?          @map("previous_value")
  nextValue     Json?          @map("next_value")
  createdAt     DateTime       @default(now()) @map("created_at")
  entry         DataStoreEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  actorUser     User?          @relation("DataStoreVersionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entryId, createdAt])
  @@index([actorUserId])
  @@map("data_store_entry_versions")
  @@schema("content")
}

model ExternalSystem {
  id         String               @id @default(uuid()) @db.Uuid
  ownerOrgId String?              @map("owner_org_id") @db.Uuid
  name       String
  systemType String               @map("system_type")
  status     String               @default("Configured")
  config     Json                 @default("{}")
  createdAt  DateTime             @default(now()) @map("created_at")
  syncRuns   IntegrationSyncRun[]

  @@index([ownerOrgId, systemType])
  @@map("external_systems")
  @@schema("integration")
}

model RegistryRecord {
  id             String   @id @default(uuid()) @db.Uuid
  source         String
  registryNumber String   @map("registry_number")
  entityType     String   @map("entity_type")
  name           String
  status         String   @default("MATCHED")
  confidence     Int      @default(95)
  payload        Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([source, registryNumber])
  @@index([source, entityType])
  @@map("registry_records")
  @@schema("integration")
}

model IntegrationSyncRun {
  id               String             @id @default(uuid()) @db.Uuid
  externalSystemId String             @map("external_system_id") @db.Uuid
  ownerOrgId       String?            @map("owner_org_id") @db.Uuid
  status           String
  direction        String
  payload          Json               @default("{}")
  startedAt        DateTime           @default(now()) @map("started_at")
  finishedAt       DateTime?          @map("finished_at")
  externalSystem   ExternalSystem     @relation(fields: [externalSystemId], references: [id], onDelete: Cascade)
  events           IntegrationEvent[]

  @@index([externalSystemId, startedAt])
  @@index([ownerOrgId])
  @@map("integration_sync_runs")
  @@schema("integration")
}

model IntegrationEvent {
  id         String              @id @default(uuid()) @db.Uuid
  syncRunId  String?             @map("sync_run_id") @db.Uuid
  ownerOrgId String?             @map("owner_org_id") @db.Uuid
  eventType  String              @map("event_type")
  status     String
  payload    Json                @default("{}")
  createdAt  DateTime            @default(now()) @map("created_at")
  syncRun    IntegrationSyncRun? @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  @@index([syncRunId])
  @@index([ownerOrgId, eventType])
  @@map("integration_events")
  @@schema("integration")
}
