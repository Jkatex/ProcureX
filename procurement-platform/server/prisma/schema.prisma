generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "organization", "procurement", "bidding", "evaluation", "contract", "financial", "compliance", "communication", "documents", "records", "intelligence", "integration", "content", "support"]
}

enum AccountType {
  USER
  ADMIN

  @@schema("identity")
}

enum VerificationStatus {
  NOT_STARTED
  DRAFT
  PENDING
  APPROVED
  REJECTED
  EXPIRED

  @@schema("identity")
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED

  @@schema("identity")
}

enum PublicPageKey {
  ABOUT_PROCUREX
  PRIVACY_POLICY
  TERMS_AND_CONDITIONS

  @@schema("content")
}

enum PublicPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("content")
}

enum OrganizationKind {
  COMPANY
  PLATFORM

  @@schema("organization")
}

enum OrganizationCapabilityName {
  BUYER
  SUPPLIER

  @@schema("organization")
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED

  @@schema("organization")
}

enum TrustTier {
  UNVERIFIED
  VERIFIED
  BRONZE
  SILVER
  GOLD
  PLATINUM

  @@schema("organization")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("organization")
}

enum TenderType {
  GOODS
  WORKS
  SERVICE
  CONSULTANCY

  @@schema("procurement")
}

enum TenderStatus {
  DRAFT
  REVIEW
  PUBLISHED
  OPEN
  CLOSED
  EVALUATION
  AWARDED
  CANCELLED

  @@schema("procurement")
}

enum ProcurementMethod {
  OPEN_TENDER
  INVITED_TENDER

  @@schema("procurement")
}

enum Visibility {
  PRIVATE
  INVITED
  PUBLIC_MARKETPLACE

  @@schema("procurement")
}

enum TenderAmendmentStatus {
  DRAFT
  PUBLISHED
  CANCELLED

  @@schema("procurement")
}

enum ContractType {
  UNIT_PRICE
  LUMP_SUM
  FRAMEWORK
  TIME_AND_MATERIALS
  OTHER

  @@schema("procurement")
}

enum BidStatus {
  DRAFT
  SUBMITTED
  WITHDRAWN
  OPENED
  UNDER_EVALUATION
  DISQUALIFIED
  AWARDED
  LOST

  @@schema("bidding")
}

enum EnvelopeType {
  ADMINISTRATIVE
  TECHNICAL
  FINANCIAL
  COMBINED

  @@schema("bidding")
}

enum BidSampleStatus {
  REQUIRED
  PENDING_SUBMISSION
  SUBMITTED
  RECEIVED
  INSPECTED
  ACCEPTED
  REJECTED

  @@schema("bidding")
}

enum DocumentReviewStatus {
  UPLOADED
  VERIFIED
  REVIEW
  REJECTED

  @@schema("documents")
}

enum EvaluationStatus {
  NOT_STARTED
  IN_PROGRESS
  LOCKED
  COMPLETED
  RETURNED

  @@schema("evaluation")
}

enum EvaluationStage {
  OPENING
  CONFLICT
  PRELIMINARY
  ELIGIBILITY
  TECHNICAL
  FINANCIAL
  CLARIFICATIONS
  COMPARISON
  REPORT
  RECOMMENDATION

  @@schema("evaluation")
}

enum WorkflowAssignmentType {
  EVALUATOR
  APPROVER
  AUDITOR
  OBSERVER

  @@schema("evaluation")
}

enum ApprovalStatus {
  WAITING
  PENDING
  APPROVED
  RETURNED
  REJECTED

  @@schema("evaluation")
}

enum RecommendationStatus {
  DRAFT
  RECOMMENDED
  APPROVED
  RETURNED
  REJECTED

  @@schema("evaluation")
}

enum ContractStatus {
  DRAFT
  NEGOTIATION
  SIGNATURE_PENDING
  SIGNED
  PENDING_ACTIVATION
  MOBILIZATION
  ACTIVE
  SUSPENDED
  AT_RISK
  COMPLETED
  WARRANTY_DEFECTS
  CLOSING
  TERMINATION_REVIEW
  TERMINATED
  CLOSED

  @@schema("contract")
}

enum SignatureStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED

  @@schema("contract")
}

enum AwardNoticeStatus {
  PENDING_RESPONSE
  ACCEPTED
  CLARIFICATION_REQUESTED
  DECLINED
  CANCELLED

  @@schema("contract")
}

enum AwardResponseAction {
  ACCEPT
  REQUEST_CLARIFICATION
  DECLINE

  @@schema("contract")
}

enum ContractPartyRole {
  BUYER
  SUPPLIER

  @@schema("contract")
}

enum ContractMilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  ACCEPTED
  REJECTED
  COMPLETED

  @@schema("contract")
}

enum ContractLifecycleItemStatus {
  OPEN
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  WAIVED
  CLOSED

  @@schema("contract")
}

enum ContractRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("contract")
}

enum ContractTerminationStatus {
  DRAFT
  NOTICE_ISSUED
  CURE_PERIOD_ACTIVE
  UNDER_REVIEW
  APPROVED
  REJECTED
  TERMINATED
  SETTLEMENT_PENDING
  DISPUTED
  CLOSED

  @@schema("contract")
}

enum ContractTerminationType {
  SUPPLIER_DEFAULT
  BUYER_DEFAULT
  CONVENIENCE
  MUTUAL
  FORCE_MAJEURE
  INSOLVENCY
  FRAUD_CORRUPTION

  @@schema("contract")
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  MATCHED
  REVIEW
  BLOCKED
  PAID
  REJECTED

  @@schema("financial")
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL

  @@schema("compliance")
}

enum ComplianceCaseStatus {
  OPEN
  INVESTIGATION
  FALSE_POSITIVE
  RESOLVED
  ESCALATED

  @@schema("compliance")
}

enum AdminActionType {
  REVIEW
  APPROVE
  RETURN
  HOLD
  FLAG
  EXPORT

  @@schema("compliance")
}

enum CommunicationKind {
  MESSAGE
  CLARIFICATION
  NOTIFICATION
  ALERT

  @@schema("communication")
}

enum CommunicationPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@schema("communication")
}

enum CommunicationStatus {
  UNREAD
  READ
  REPLIED
  PENDING_RESPONSE
  RESOLVED
  ARCHIVED
  DELETED
  ACTION_REQUIRED
  COMPLETED

  @@schema("communication")
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@schema("support")
}

enum SupportTicketStatus {
  OPEN
  WAITING_ON_SUPPORT
  WAITING_ON_USER
  RESOLVED
  CLOSED

  @@schema("support")
}

model User {
  id                        String                       @id @default(uuid()) @db.Uuid
  email                     String                       @unique
  phone                     String?
  displayName               String                       @map("display_name")
  passwordHash              String?                      @map("password_hash")
  accountType               AccountType                  @default(USER) @map("account_type")
  verificationStatus        VerificationStatus           @default(NOT_STARTED) @map("verification_status")
  metadata                  Json                         @default("{}")
  createdAt                 DateTime                     @default(now()) @map("created_at")
  updatedAt                 DateTime                     @updatedAt @map("updated_at")
  accounts                  Account[]
  sessions                  Session[]
  policyAcceptances         UserPolicyAcceptance[]
  mfaFactors                MfaFactor[]
  identityChallenges        IdentityChallenge[]
  memberships               OrganizationMember[]
  verificationProfiles      VerificationProfile[]
  verificationHistory       VerificationProfileHistory[]
  digitalSignatures         DigitalSignature[]
  signedActions             SignedAction[]
  signingCredentials        SigningCredential[]
  keyphraseRecoveries       KeyphraseRecovery[]
  screeningChecks           ScreeningCheck[]
  trustTierHistory          TrustTierHistory[]
  permissionOverrides       PermissionOverride[]
  uploadedDocuments         DocumentObject[]             @relation("DocumentUploader")
  ownedTenders              Tender[]                     @relation("TenderOwner")
  createdTenderAmendments   TenderAmendment[]            @relation("TenderAmendmentCreator")
  savedTenders              SavedTender[]
  submittedBids             Bid[]                        @relation("BidSubmitter")
  workflowAssignments       WorkflowAssignment[]
  evaluationScores          EvaluationScore[]            @relation("EvaluationScoreEvaluator")
  issuedAwardNotices        AwardNotice[]                @relation("AwardNoticeIssuer")
  respondedAwardNotices     AwardNotice[]                @relation("AwardNoticeResponder")
  awardResponses            AwardResponse[]              @relation("AwardResponseActor")
  contractSignatures        ContractSignature[]          @relation("ContractSignatureSigner")
  contractManagementPlans   ContractManagementPlan[]     @relation("ContractManagementPlanManager")
  contractInspections       ContractInspection[]         @relation("ContractInspectionInspector")
  contractRisks             ContractRisk[]               @relation("ContractRiskResponsible")
  contractMilestoneEvidence ContractMilestoneEvidence[]  @relation("ContractMilestoneEvidenceUploader")
  preference                UserPreference?
  supportTickets            SupportTicket[]              @relation("SupportTicketOwner")
  supportComments           SupportTicketComment[]       @relation("SupportTicketCommentActor")
  auditEvents               AuditEvent[]                 @relation("AuditActor")
  adminActions              AdminAction[]                @relation("AdminActionActor")
  revertedAdminActions      AdminAction[]                @relation("AdminActionRevertedBy")
  createdComplianceRules    ComplianceRule[]             @relation("ComplianceRuleCreator")
  ownedDataStoreEntries     DataStoreEntry[]             @relation("DataStoreOwnerUser")
  createdDataStoreEntries   DataStoreEntry[]             @relation("DataStoreCreatedByUser")
  updatedDataStoreEntries   DataStoreEntry[]             @relation("DataStoreUpdatedByUser")
  deletedDataStoreEntries   DataStoreEntry[]             @relation("DataStoreDeletedByUser")
  dataStoreVersions         DataStoreEntryVersion[]      @relation("DataStoreVersionActor")
  generatedOfficialDocuments OfficialDocumentVersion[]    @relation("OfficialDocumentGeneratedBy")

  @@map("users")
  @@schema("identity")
}

model UserPreference {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  preferredLanguage String   @default("en") @map("preferred_language")
  timezone          String   @default("Africa/Dar_es_Salaam")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
  @@schema("identity")
}

model Account {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  provider       String      @default("password")
  providerUserId String?     @map("provider_user_id")
  accountType    AccountType @default(USER) @map("account_type")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("accounts")
  @@schema("identity")
}

model UserPolicyAcceptance {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  termsVersionId   String            @map("terms_version_id") @db.Uuid
  privacyVersionId String            @map("privacy_version_id") @db.Uuid
  acceptedAt       DateTime          @default(now()) @map("accepted_at")
  source           String            @default("registration")
  ipAddress        String?           @map("ip_address")
  userAgent        String?           @map("user_agent")
  payload          Json              @default("{}")
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  termsVersion     PublicPageVersion @relation("TermsPolicyAcceptances", fields: [termsVersionId], references: [id], onDelete: Restrict)
  privacyVersion   PublicPageVersion @relation("PrivacyPolicyAcceptances", fields: [privacyVersionId], references: [id], onDelete: Restrict)

  @@index([userId, acceptedAt])
  @@index([termsVersionId])
  @@index([privacyVersionId])
  @@map("user_policy_acceptances")
  @@schema("identity")
}

model Session {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  tokenHash      String        @map("token_hash")
  status         SessionStatus @default(ACTIVE)
  expiresAt      DateTime      @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([organizationId])
  @@map("sessions")
  @@schema("identity")
}

model MfaFactor {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  secretRef String?  @map("secret_ref")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_factors")
  @@schema("identity")
}

model IdentityChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  purpose    String
  target     String
  codeHash   String    @map("code_hash")
  status     String    @default("PENDING")
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, status])
  @@index([target, purpose, status])
  @@map("identity_challenges")
  @@schema("identity")
}

model VerificationProfile {
  id                String                       @id @default(uuid()) @db.Uuid
  userId            String                       @map("user_id") @db.Uuid
  organizationId    String?                      @map("organization_id") @db.Uuid
  status            VerificationStatus           @default(DRAFT)
  registrySource    String?                      @map("registry_source")
  registryNumber    String?                      @map("registry_number")
  payload           Json                         @default("{}")
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")
  user              User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization?                @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  documents         VerificationDocument[]
  digitalSignatures DigitalSignature[]
  screeningChecks   ScreeningCheck[]
  trustTierHistory  TrustTierHistory[]
  history           VerificationProfileHistory[]

  @@index([userId])
  @@index([organizationId, status])
  @@map("verification_profiles")
  @@schema("identity")
}

model VerificationProfileHistory {
  id                    String              @id @default(uuid()) @db.Uuid
  verificationProfileId String              @map("verification_profile_id") @db.Uuid
  userId                String              @map("user_id") @db.Uuid
  organizationId        String?             @map("organization_id") @db.Uuid
  status                VerificationStatus
  registrySource        String?             @map("registry_source")
  registryNumber        String?             @map("registry_number")
  event                 String
  payload               Json                @default("{}")
  createdAt             DateTime            @default(now()) @map("created_at")
  verificationProfile   VerificationProfile @relation(fields: [verificationProfileId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([verificationProfileId, createdAt])
  @@index([userId, createdAt])
  @@map("verification_profile_history")
  @@schema("identity")
}

model DigitalSignature {
  id                    String              @id @default(uuid()) @db.Uuid
  verificationProfileId String              @map("verification_profile_id") @db.Uuid
  userId                String              @map("user_id") @db.Uuid
  organizationId        String?             @map("organization_id") @db.Uuid
  signerName            String              @map("signer_name")
  signerTitle           String?             @map("signer_title")
  consentVersion        String              @map("consent_version")
  consentTitle          String              @map("consent_title")
  canonicalPayloadHash  String              @map("canonical_payload_hash")
  signatureHash         String              @map("signature_hash")
  status                String              @default("SIGNED")
  signedAt              DateTime            @default(now()) @map("signed_at")
  metadata              Json                @default("{}")
  providerMetadata      Json                @default("{}") @map("provider_metadata")
  blockchainMetadata    Json                @default("{}") @map("blockchain_metadata")
  createdAt             DateTime            @default(now()) @map("created_at")
  verificationProfile   VerificationProfile @relation(fields: [verificationProfileId], references: [id], onDelete: Cascade)
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([verificationProfileId, signedAt])
  @@index([userId, signedAt])
  @@index([signatureHash])
  @@map("digital_signatures")
  @@schema("identity")
}

model SigningCredential {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  status              String    @default("ACTIVE")
  publicKeyPem        String    @map("public_key_pem") @db.Text
  keyFingerprint      String    @unique @map("key_fingerprint")
  encryptedPrivateKey String    @map("encrypted_private_key") @db.Text
  kdfMetadata         Json      @default("{}") @map("kdf_metadata")
  encryptionMetadata  Json      @default("{}") @map("encryption_metadata")
  providerMetadata    Json      @default("{}") @map("provider_metadata")
  revokedAt           DateTime? @map("revoked_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  signedActions       SignedAction[]

  @@index([userId, status])
  @@map("signing_credentials")
  @@schema("identity")
}

model SignedAction {
  id                   String            @id @default(uuid()) @db.Uuid
  userId               String            @map("user_id") @db.Uuid
  organizationId       String?           @map("organization_id") @db.Uuid
  signingCredentialId  String            @map("signing_credential_id") @db.Uuid
  moduleKey            String            @map("module_key")
  actionKey            String            @map("action_key")
  entityType           String            @map("entity_type")
  entityRef            String            @map("entity_ref")
  canonicalPayloadHash String            @map("canonical_payload_hash")
  signatureHash        String            @unique @map("signature_hash")
  keyFingerprint       String            @map("key_fingerprint")
  signedAt             DateTime          @default(now()) @map("signed_at")
  requestMetadata      Json              @default("{}") @map("request_metadata")
  payload              Json              @default("{}")
  providerMetadata     Json              @default("{}") @map("provider_metadata")
  createdAt            DateTime          @default(now()) @map("created_at")
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  signingCredential    SigningCredential @relation(fields: [signingCredentialId], references: [id], onDelete: Restrict)

  @@index([userId, signedAt])
  @@index([organizationId, signedAt])
  @@index([moduleKey, actionKey])
  @@index([entityType, entityRef])
  @@map("signed_actions")
  @@schema("identity")
}

model KeyphraseRecovery {
  id                    String        @id @default(uuid()) @db.Uuid
  userId                String?       @map("user_id") @db.Uuid
  organizationId        String?       @map("organization_id") @db.Uuid
  emailChallengeId      String?       @map("email_challenge_id") @db.Uuid
  phoneChallengeId      String?       @map("phone_challenge_id") @db.Uuid
  status                String        @default("STARTED")
  email                 String
  phoneMasked           String?       @map("phone_masked")
  emailVerifiedAt       DateTime?     @map("email_verified_at")
  phoneVerifiedAt       DateTime?     @map("phone_verified_at")
  completedAt           DateTime?     @map("completed_at")
  oldKeyFingerprint     String?       @map("old_key_fingerprint")
  newKeyFingerprint     String?       @map("new_key_fingerprint")
  requestMetadata       Json          @default("{}") @map("request_metadata")
  payload               Json          @default("{}")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  user                  User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([status, createdAt])
  @@map("keyphrase_recoveries")
  @@schema("identity")
}

model VerificationDocument {
  id                    String               @id @default(uuid()) @db.Uuid
  verificationProfileId String               @map("verification_profile_id") @db.Uuid
  documentId            String               @map("document_id") @db.Uuid
  status                DocumentReviewStatus @default(UPLOADED)
  createdAt             DateTime             @default(now()) @map("created_at")
  verificationProfile   VerificationProfile  @relation(fields: [verificationProfileId], references: [id], onDelete: Cascade)
  document              DocumentObject       @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([verificationProfileId])
  @@index([documentId])
  @@map("verification_documents")
  @@schema("identity")
}

model ScreeningCheck {
  id                    String               @id @default(uuid()) @db.Uuid
  userId                String               @map("user_id") @db.Uuid
  verificationProfileId String?              @map("verification_profile_id") @db.Uuid
  organizationId        String?              @map("organization_id") @db.Uuid
  provider              String
  status                String
  reasons               Json                 @default("[]")
  providerMetadata      Json                 @default("{}") @map("provider_metadata")
  createdAt             DateTime             @default(now()) @map("created_at")
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  verificationProfile   VerificationProfile? @relation(fields: [verificationProfileId], references: [id], onDelete: SetNull)
  organization          Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([verificationProfileId, createdAt])
  @@index([organizationId, createdAt])
  @@index([status])
  @@map("screening_checks")
  @@schema("identity")
}

model Organization {
  id                        String                       @id @default(uuid()) @db.Uuid
  name                      String                       @unique
  kind                      OrganizationKind             @default(COMPANY)
  taxId                     String?                      @map("tax_id")
  country                   String                       @default("TZ")
  metadata                  Json                         @default("{}")
  createdAt                 DateTime                     @default(now()) @map("created_at")
  updatedAt                 DateTime                     @updatedAt @map("updated_at")
  members                   OrganizationMember[]
  capabilities              OrganizationCapability[]
  profile                   OrganizationProfile?
  buyerProfile              BuyerProfile?
  supplierProfile           SupplierProfile?
  sessions                  Session[]
  verificationProfiles      VerificationProfile[]
  verificationHistory       VerificationProfileHistory[]
  digitalSignatures         DigitalSignature[]
  signedActions             SignedAction[]
  keyphraseRecoveries       KeyphraseRecovery[]
  screeningChecks           ScreeningCheck[]
  trustTierHistory          TrustTierHistory[]
  permissionOverrides       PermissionOverride[]
  documents                 DocumentObject[]
  tendersAsBuyer            Tender[]                     @relation("TenderBuyerOrg")
  tenderAmendments          TenderAmendment[]            @relation("TenderAmendmentBuyerOrg")
  savedTenders              SavedTender[]
  procurementPlans          ProcurementPlan[]            @relation("ProcurementPlanOwnerOrg")
  bidsAsBuyer               Bid[]                        @relation("BidBuyerOrg")
  bidsAsSupplier            Bid[]                        @relation("BidSupplierOrg")
  bidSamples                BidSample[]                  @relation("BidSampleSupplierOrg")
  evaluationWorkspaces      EvaluationWorkspace[]        @relation("EvaluationBuyerOrg")
  awardNoticesAsBuyer       AwardNotice[]                @relation("AwardNoticeBuyerOrg")
  awardNoticesAsSupplier    AwardNotice[]                @relation("AwardNoticeSupplierOrg")
  awardResponses            AwardResponse[]              @relation("AwardResponseActorOrg")
  contractsAsBuyer          Contract[]                   @relation("ContractBuyerOrg")
  contractsAsSupplier       Contract[]                   @relation("ContractSupplierOrg")
  contractSignatures        ContractSignature[]          @relation("ContractSignatureSignerOrg")
  contractMilestoneEvidence ContractMilestoneEvidence[]  @relation("ContractMilestoneEvidenceUploaderOrg")
  supplierPerformanceBuyer  SupplierPerformanceRecord[]  @relation("SupplierPerformanceBuyerOrg")
  supplierPerformanceVendor SupplierPerformanceRecord[]  @relation("SupplierPerformanceSupplierOrg")
  purchaseOrders            PurchaseOrder[]              @relation("PurchaseOrderBuyerOrg")
  invoicesAsBuyer           Invoice[]                    @relation("InvoiceBuyerOrg")
  invoicesAsSupplier        Invoice[]                    @relation("InvoiceSupplierOrg")
  communicationOwned        CommunicationItem[]          @relation("CommunicationOwnerOrg")
