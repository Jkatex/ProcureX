{
  "name": "@procurex/server",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "ProcureX TypeScript Express backend and Prisma database foundation.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:example": "node ../scripts/run-server-dev.mjs .env.example",
    "build": "node ../scripts/run-with-env.mjs . server/.env.example -- prisma generate --schema server/prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "db:validate": "node ../scripts/run-with-env.mjs . server/.env.example -- prisma validate --schema server/prisma/schema.prisma",
    "db:generate": "node ../scripts/run-with-env.mjs . server/.env.example -- prisma generate --schema server/prisma/schema.prisma",
    "db:migrate": "node ../scripts/run-with-env.mjs . server/.env.example -- prisma migrate dev --schema server/prisma/schema.prisma",
    "db:deploy": "node ../scripts/run-with-env.mjs . server/.env.example -- prisma migrate deploy --schema server/prisma/schema.prisma",
    "db:seed": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/seed.ts",
    "db:seed:evaluation-intake-demo": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/seed-evaluation-intake-demo.ts",
    "db:seed:marketplace-demo": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/seed-marketplace-demo.ts",
    "db:seed:award-ready-demo": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/seed-award-ready-demo.ts",
    "db:seed:demo-evaluation-award": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/seed-demo-evaluation-award.ts",
    "db:seed:award-contract-demo": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/seed-award-contract-demo.ts cleanup",
    "db:cleanup:award-contract-demo": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/seed-award-contract-demo.ts cleanup",
    "db:cleanup:demo-admin": "node ../scripts/run-with-env.mjs server .env.example -- tsx prisma/cleanup-demo-admin-only.ts",
    "db:seed:twice": "npm run db:seed && npm run db:seed",
    "verify:rls": "node ../scripts/run-with-env.mjs server .env.example -- tsx src/verify-rls.ts",
    "validate:help-centre": "tsx src/modules/help-centre/validate-help-centre.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "@elastic/elasticsearch": "^8.15.2",
    "@prisma/client": "^6.19.3",
    "@procurex/shared": "0.1.0",
    "@types/busboy": "^1.5.4",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "resend": "^6.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11"
  }
}
